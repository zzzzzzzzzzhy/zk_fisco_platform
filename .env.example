# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/competition_platform?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_password

# Redis 配置
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_DATABASE=1
SPRING_REDIS_USERNAME=default
SPRING_REDIS_PASSWORD=your_redis_password

# JWT 密钥（生产环境必须替换）
JWT_SECRET=your-256-bit-secret-key-please-change-in-production

# 区块链配置（可选，不填则链上功能不可用）
BLOCKCHAIN_ADMIN_PRIVATE_KEY=

# 存储配置（默认使用 MinIO）
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# IPFS/4Everland（可选，STORAGE_PROVIDER=ipfs 时填写）
IPFS_ENDPOINT=
IPFS_ACCESS_KEY=
IPFS_SECRET_KEY=
IPFS_BUCKET=
