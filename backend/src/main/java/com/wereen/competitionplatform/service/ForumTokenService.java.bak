/**
 * 论坛代币服务
 * 集成DAppDemo1的MTK代币到论坛激励机制
 */
@Slf4j
@Service
public class ForumTokenService {

    @Value("${blockchain.polygon.rpc-url:https://rpc-amoy.polygon.technology/}")
    private String polygonRpcUrl;

    @Value("${blockchain.polygon.chain-id:80002}")
    private Long polygonChainId;

    @Value("${blockchain.forum-token.extension-address:}")
    private String forumTokenExtensionAddress;

    @Value("${blockchain.mtk.token-address:0x2A252B89915708C6Be863D4110a4E05e9437e3b0}")
    private String mtkTokenAddress;

    @Value("${blockchain.admin.private-key:}")
    private String adminPrivateKey;

    @Autowired
    private UserService userService;

    @Autowired
    private BlockchainService blockchainService;

    @Autowired
    private UserWalletService userWalletService;

    private Web3j web3j;
    private Credentials adminCredentials;

    /**
     * 奖励配置 (MTK代币，18位小数)
     */
    private static final BigInteger POST_REWARD = BigInteger.valueOf(10).multiply(BigInteger.TEN.pow(18));
    private static final BigInteger COMMENT_REWARD = BigInteger.valueOf(2).multiply(BigInteger.TEN.pow(18));
    private static final BigInteger DAILY_CHECKIN_REWARD = BigInteger.valueOf(5).multiply(BigInteger.TEN.pow(18));
    private static final BigInteger FEATURED_POST_REWARD = BigInteger.valueOf(50).multiply(BigInteger.TEN.pow(18));
    private static final BigInteger CONSECUTIVE_BONUS = BigInteger.valueOf(30).multiply(BigInteger.TEN.pow(18));

    /**
     * 初始化Web3连接
     */
    private void initWeb3j() {
        if (web3j == null) {
            web3j = Web3j.build(new HttpService(polygonRpcUrl));
            if (adminPrivateKey != null && !adminPrivateKey.isEmpty()) {
                adminCredentials = Credentials.create(adminPrivateKey);
            }
        }
    }

    /**
     * 发布帖子奖励
     */
    @Transactional
    @Async
    public CompletableFuture<Void> rewardPost(Long userId, String postId) {
        try {
            initWeb3j();

            User user = userService.getById(userId);
            if (user == null) {
                log.error("用户不存在: {}", userId);
                return CompletableFuture.completedFuture(null);
            }

            UserWallet wallet = userWalletService.getUserWallet(userId);
            if (wallet == null) {
                log.error("用户钱包地址不存在: {}", userId);
                return CompletableFuture.completedFuture(null);
            }

            // 调用合约发放奖励
            TransactionReceipt receipt = callForumTokenExtension(
                "rewardPost",
                Arrays.asList(
                    new org.web3j.abi.datatypes.Address(wallet.getWalletAddress()),
                    new org.web3j.abi.datatypes.Utf8String(postId)
                )
            );

            if (receipt.isStatusOK()) {
                log.info("帖子奖励发放成功: userId={}, postId={}, txHash={}",
                    userId, postId, receipt.getTransactionHash());

                // 记录奖励日志
                saveRewardLog(userId, postId, "POST", POST_REWARD, receipt.getTransactionHash());
            } else {
                log.error("帖子奖励发放失败: userId={}, postId={}", userId, postId);
            }

        } catch (Exception e) {
            log.error("帖子奖励处理异常: userId={}, postId={}", userId, postId, e);
        }

        return CompletableFuture.completedFuture(null);
    }

    /**
     * 评论奖励
     */
    @Transactional
    @Async
    public CompletableFuture<Void> rewardComment(Long userId, String commentId) {
        try {
            initWeb3j();

            User user = userService.getById(userId);
            if (user == null) {
                log.error("用户不存在: {}", userId);
                return CompletableFuture.completedFuture(null);
            }

            UserWallet wallet = userWalletService.getUserWallet(userId);
            if (wallet == null) {
                log.error("用户钱包地址不存在: {}", userId);
                return CompletableFuture.completedFuture(null);
            }

            TransactionReceipt receipt = callForumTokenExtension(
                "rewardComment",
                Arrays.asList(
                    new org.web3j.abi.datatypes.Address(wallet.getWalletAddress()),
                    new org.web3j.abi.datatypes.Utf8String(commentId)
                )
            );

            if (receipt.isStatusOK()) {
                log.info("评论奖励发放成功: userId={}, commentId={}, txHash={}",
                    userId, commentId, receipt.getTransactionHash());

                saveRewardLog(userId, commentId, "COMMENT", COMMENT_REWARD, receipt.getTransactionHash());
            } else {
                log.error("评论奖励发放失败: userId={}, commentId={}", userId, commentId);
            }

        } catch (Exception e) {
            log.error("评论奖励处理异常: userId={}, commentId={}", userId, commentId, e);
        }

        return CompletableFuture.completedFuture(null);
    }

    /**
     * 每日签到奖励
     */
    @Transactional
    public Result<Boolean> dailyCheckin(Long userId) {
        try {
            initWeb3j();

            User user = userService.getById(userId);
            if (user == null) {
                return Result.fail("用户不存在");
            }

            UserWallet wallet = userWalletService.getUserWallet(userId);
            if (wallet == null) {
                return Result.fail("用户钱包地址不存在，请先绑定钱包");
            }

            // 检查今日是否已签到
            if (!canCheckinToday(wallet.getWalletAddress())) {
                return Result.fail("今日已签到");
            }

            TransactionReceipt receipt = callForumTokenExtension(
                "dailyCheckin",
                Arrays.asList(new org.web3j.abi.datatypes.Address(wallet.getWalletAddress()))
            );

            if (receipt.isStatusOK()) {
                log.info("每日签到成功: userId={}, txHash={}", userId, receipt.getTransactionHash());

                saveRewardLog(userId, "daily_checkin", "DAILY_CHECKIN",
                    DAILY_CHECKIN_REWARD, receipt.getTransactionHash());

                return Result.success(true);
            } else {
                return Result.fail("签到失败，请稍后重试");
            }

        } catch (Exception e) {
            log.error("每日签到异常: userId={}", userId, e);
            return Result.fail("签到失败：" + e.getMessage());
        }
    }

    /**
     * 精华帖子奖励
     */
    @Transactional
    public Result<Boolean> rewardFeaturedPost(Long userId, String postId) {
        try {
            initWeb3j();

            User user = userService.getById(userId);
            if (user == null) {
                return Result.fail("用户不存在");
            }

            UserWallet wallet = userWalletService.getUserWallet(userId);
            if (wallet == null) {
                return Result.fail("用户钱包地址不存在");
            }

            TransactionReceipt receipt = callForumTokenExtension(
                "rewardFeaturedPost",
                Arrays.asList(
                    new org.web3j.abi.datatypes.Address(wallet.getWalletAddress()),
                    new org.web3j.abi.datatypes.Utf8String(postId)
                )
            );

            if (receipt.isStatusOK()) {
                log.info("精华帖子奖励发放成功: userId={}, postId={}, txHash={}",
                    userId, postId, receipt.getTransactionHash());

                saveRewardLog(userId, postId, "FEATURED_POST", FEATURED_POST_REWARD, receipt.getTransactionHash());

                return Result.success(true);
            } else {
                return Result.fail("精华帖子奖励发放失败");
            }

        } catch (Exception e) {
            log.error("精华帖子奖励异常: userId={}, postId={}", userId, postId, e);
            return Result.fail("奖励发放失败：" + e.getMessage());
        }
    }

    /**
     * 批量奖励帖子
     */
    @Transactional
    @Async
    public CompletableFuture<Void> batchRewardPosts(List<Long> userIds, List<String> postIds) {
        try {
            if (userIds.size() != postIds.size()) {
                log.error("批量奖励失败：用户ID和帖子ID数量不匹配");
                return CompletableFuture.completedFuture(null);
            }

            initWeb3j();

            List<String> walletAddresses = userIds.stream()
                .map(userId -> {
                    UserWallet wallet = userWalletService.getUserWallet(userId);
                    return wallet != null ? wallet.getWalletAddress() : null;
                })
                .toList();

            // 构建参数
            org.web3j.abi.datatypes.DynamicArray<org.web3j.abi.datatypes.Address> addresses =
                new org.web3j.abi.datatypes.DynamicArray<>(
                    org.web3j.abi.datatypes.Address.class,
                    walletAddresses.stream()
                        .filter(addr -> addr != null)
                        .map(org.web3j.abi.datatypes.Address::new)
                        .toList()
                );

            org.web3j.abi.datatypes.DynamicArray<org.web3j.abi.datatypes.Utf8String> contentIds =
                new org.web3j.abi.datatypes.DynamicArray<>(
                    org.web3j.abi.datatypes.Utf8String.class,
                    postIds.stream()
                        .map(org.web3j.abi.datatypes.Utf8String::new)
                        .toList()
                );

            Uint8 rewardType = new Uint8(0); // POST

            TransactionReceipt receipt = callForumTokenExtension(
                "batchRewardPosts",
                Arrays.asList(addresses, contentIds, rewardType)
            );

            if (receipt.isStatusOK()) {
                log.info("批量帖子奖励发放成功: txHash={}", receipt.getTransactionHash());
            } else {
                log.error("批量帖子奖励发放失败");
            }

        } catch (Exception e) {
            log.error("批量帖子奖励异常", e);
        }

        return CompletableFuture.completedFuture(null);
    }

    /**
     * 获取用户代币余额
     */
    public BigDecimal getUserTokenBalance(Long userId) {
        try {
            initWeb3j();

            UserWallet wallet = userWalletService.getUserWallet(userId);
            if (wallet == null) {
                return BigDecimal.ZERO;
            }

            // 调用MTK代币合约的balanceOf方法
            Function function = new Function(
                "balanceOf",
                Arrays.asList(new org.web3j.abi.datatypes.Address(wallet.getWalletAddress())),
                Arrays.asList(new TypeReference<Uint256>() {}));

            BigInteger balance = executeEthCall(function, mtkTokenAddress);

            // MTK有18位小数
            return new BigDecimal(balance).divide(BigDecimal.TEN.pow(18));

        } catch (Exception e) {
            log.error("获取用户代币余额异常: userId={}", userId, e);
            return BigDecimal.ZERO;
        }
    }

    /**
     * 获取用户奖励信息
     */
    public ForumRewardInfo getUserRewardInfo(Long userId) {
        try {
            initWeb3j();

            UserWallet wallet = userWalletService.getUserWallet(userId);
            if (wallet == null) {
                return null;
            }

            Function function = new Function(
                "getUserRewardInfo",
                Arrays.asList(new org.web3j.abi.datatypes.Address(wallet.getWalletAddress())),
                Arrays.asList(
                    new TypeReference<Uint256>() {},
                    new TypeReference<Uint256>() {},
                    new TypeReference<Uint256>() {},
                    new TypeReference<Uint256>() {}
                ));

            List<Type> result = executeEthCallForMultipleResults(function, forumTokenExtensionAddress);

            if (result.size() >= 4) {
                return ForumRewardInfo.builder()
                    .userId(userId)
                    .lastCheckinTime(LocalDateTime.ofEpochSecond(
                        ((Uint256) result.get(0)).getValue().longValue(), 0, null))
                    .consecutiveDays(((Uint256) result.get(1)).getValue().intValue())
                    .dailyRewardAmount(new BigDecimal(((Uint256) result.get(2)).getValue())
                        .divide(BigDecimal.TEN.pow(18)))
                    .totalRewarded(new BigDecimal(((Uint256) result.get(3)).getValue())
                        .divide(BigDecimal.TEN.pow(18)))
                    .build();
            }

        } catch (Exception e) {
            log.error("获取用户奖励信息异常: userId={}", userId, e);
        }

        return null;
    }

    /**
     * 检查今日是否可以签到
     */
    public boolean canCheckinToday(Long userId) {
        try {
            initWeb3j();

            UserWallet wallet = userWalletService.getUserWallet(userId);
            if (wallet == null) {
                return false;
            }

            Function function = new Function(
                "canCheckinToday",
                Arrays.asList(new org.web3j.abi.datatypes.Address(wallet.getWalletAddress())),
                Arrays.asList(new TypeReference<org.web3j.abi.datatypes.Bool>() {}));

            Boolean result = executeEthCall(function, forumTokenExtensionAddress);
            return result != null && result;

        } catch (Exception e) {
            log.error("检查签到状态异常: userId={}", userId, e);
            return false;
        }
    }

    /**
     * 定时任务：重置每日奖励计数
     */
    @Scheduled(cron = "0 0 1 * * ?") // 每天凌晨1点执行
    public void resetDailyRewards() {
        try {
            log.info("开始执行每日奖励重置任务");

            initWeb3j();

            TransactionReceipt receipt = callForumTokenExtension("resetDailyRewards", Arrays.asList());

            if (receipt.isStatusOK()) {
                log.info("每日奖励重置任务执行成功: txHash={}", receipt.getTransactionHash());
            } else {
                log.error("每日奖励重置任务执行失败");
            }

        } catch (Exception e) {
            log.error("每日奖励重置任务异常", e);
        }
    }

    // 私有方法

    private TransactionReceipt callForumTokenExtension(String functionName, List<Type> inputParameters)
            throws IOException {

        if (forumTokenExtensionAddress == null || forumTokenExtensionAddress.isEmpty()) {
            throw new RuntimeException("论坛代币扩展合约地址未配置");
        }

        Function function = new Function(
            functionName,
            inputParameters,
            Arrays.asList());

        return blockchainService.executeTransaction(
            forumTokenExtensionAddress,
            function,
            adminCredentials);
    }

    private <T> T executeEthCall(Function function, String contractAddress) throws IOException {
        org.web3j.protocol.core.methods.response.EthCall ethCall = web3j.ethCall(
            org.web3j.protocol.core.methods.request.Transaction.createEthCallTransaction(
                null, contractAddress, function.encode()),
            DefaultBlockParameterName.LATEST)
            .send();

        if (ethCall.hasError()) {
            throw new RuntimeException("Eth call error: " + ethCall.getError().getMessage());
        }

        return FunctionReturner.decodeReturnValue(function.getOutputParameters(), ethCall.getValue());
    }

    private List<Type> executeEthCallForMultipleResults(Function function, String contractAddress) throws IOException {
        org.web3j.protocol.core.methods.response.EthCall ethCall = web3j.ethCall(
            org.web3j.protocol.core.methods.request.Transaction.createEthCallTransaction(
                null, contractAddress, function.encode()),
            DefaultBlockParameterName.LATEST)
            .send();

        if (ethCall.hasError()) {
            throw new RuntimeException("Eth call error: " + ethCall.getError().getMessage());
        }

        return FunctionReturner.decodeReturnValues(function.getOutputParameters(), ethCall.getValue());
    }

    private void saveRewardLog(Long userId, String contentId, String rewardType,
                              BigInteger amount, String txHash) {
        // 保存奖励记录到数据库
        // 这里需要调用相应的DAO或Service
        log.info("保存奖励记录: userId={}, contentId={}, type={}, amount={}, txHash={}",
            userId, contentId, rewardType, amount, txHash);
    }

    /**
     * 奖励信息DTO
     */
    @Data
    @Builder
    public static class ForumRewardInfo {
        private Long userId;
        private LocalDateTime lastCheckinTime;
        private Integer consecutiveDays;
        private BigDecimal dailyRewardAmount;
        private BigDecimal totalRewarded;
    }
}